{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "blank_line_before_statement": {
            "statements": [
                "return",
                "throw",
                "try"
            ]
        },
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "single_quote": true
    }
}
